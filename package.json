{
  "name": "bansa",
  "version": "0.0.50",
  "description": "",
  "keywords": [
    "bansa",
    "react",
    "state"
  ],
  "homepage": "https://github.com/cgiosy/bansa",
  "license": "MIT",
  "author": "cgiosy",
  "repository": {
    "type": "git",
    "url": "git://github.com/cgiosy/bansa.git"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "default": "./dist/react.mjs"
    },
    "./atom": {
      "types": "./dist/atom.d.mts",
      "default": "./dist/atom.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:bundler": "tsdown src/index.ts src/react.tsx src/atom.ts src/utils.ts --dts --target=es2022",
    "build:browser": "tsdown src/index.ts --dts --minify --target=es2022 --platform=browser --out-dir=dist/browser",
    "test": "vitest",
    "lint": "pnpm check",
    "check": "tsc -b --noEmit && oxlint && oxfmt --check",
    "format": "oxlint --fix && oxfmt",
    "prepare": "pnpm run build"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@types/react": ">=18.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.10.0"
}
